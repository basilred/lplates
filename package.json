{
  "name": "lplates",
  "private": true,
  "version": "2.8.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/download-libs.js && vite",
    "dev:https": "node scripts/download-libs.js && vite --host",
    "build": "node scripts/download-libs.js && tsc && vite build",
    "postinstall": "node scripts/download-libs.js",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:pwa": "playwright test --config playwright.pwa.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "d3-geo": "^3.1.1",
    "prop-types": "^15.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-simple-maps": "^3.0.0",
    "tesseract.js": "^7.0.0",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-simple-maps": "^3.0.6",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "gh-pages": "^6.3.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^4.1.5"
  }
}
